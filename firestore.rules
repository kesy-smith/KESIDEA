rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'createdAt'])
        && data.keys().size() == 4
        && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId)
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'email', 'uid', 'createdAt'])
          && incoming().uid == existing().uid
          && (incoming().createdAt == existing().createdAt || incoming().createdAt == request.time)
        );
    }

    // --- Score Validation ---
    function isValidScore(data) {
      return data.keys().hasAll(['userId', 'theme', 'score', 'total', 'timestamp'])
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.theme is string && data.theme.size() <= 50
        && data.score is int && data.score >= 0 && data.score <= data.total
        && data.total is int && data.total > 0 && data.total <= 100
        && data.timestamp == request.time;
    }

    match /scores/{scoreId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidScore(incoming()) && isValidId(scoreId);
      // Scores are immutable
      allow update, delete: if false;
    }
  }
}
